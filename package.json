{
  "name": "swipertab",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node scripts/vite-target.mjs firefox build --watch --mode development",
    "dev:firefox": "node scripts/vite-target.mjs firefox build --watch --mode development",
    "dev:chrome": "node scripts/vite-target.mjs chrome build --watch --mode development",
    "build": "npm run build:firefox && npm run build:chrome",
    "build:firefox": "tsc -b --noEmit && node scripts/vite-target.mjs firefox build",
    "build:chrome": "tsc -b --noEmit && node scripts/vite-target.mjs chrome build",
    "typecheck": "tsc -b --noEmit",
    "package": "npm run package:firefox && npm run package:chrome && npm run package:source",
    "package:firefox": "npm run build:firefox && node scripts/package.mjs firefox",
    "package:chrome": "npm run build:chrome && node scripts/package.mjs chrome",
    "package:source": "node scripts/package.mjs source"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "framer-motion": "^11.11.0",
    "lucide-react": "^0.453.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.5.4",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vite-plugin-web-extension": "^4.4.3"
  }
}
